{
  "name": "@microlink/function",
  "description": "Write JavaScript functions and run them remotely with Microlink — Puppeteer access, npm packages, and zero infrastructure.",
  "homepage": "https://function.microlink.io",
  "version": "0.2.7",
  "types": "src/index.d.ts",
  "exports": {
    "types": "./src/index.d.ts",
    "require": "./src/index.js",
    "import": "./src/index.mjs",
    "default": "./src/index.mjs"
  },
  "author": {
    "email": "josefrancisco.verdu@gmail.com",
    "name": "Kiko Beats",
    "url": "https://github.com/Kikobeats"
  },
  "repository": {
    "directory": "packages/function",
    "type": "git",
    "url": "git+https://github.com/microlinkhq/microlink.git"
  },
  "bugs": {
    "url": "https://github.com/microlinkhq/microlink/issues"
  },
  "keywords": [
    "browserless",
    "chrome",
    "chromium",
    "function",
    "microlink",
    "playwright",
    "puppeteer",
    "serverless"
  ],
  "dependencies": {
    "@microlink/mql": "workspace:*",
    "lz-ts": "~1.1.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "latest",
    "@rollup/plugin-node-resolve": "latest",
    "@rollup/plugin-replace": "latest",
    "@rollup/plugin-terser": "latest",
    "async-listen": "latest",
    "ava": "latest",
    "cheerio": "latest",
    "execa": "latest",
    "puppeteer-core": "latest",
    "rollup": "latest",
    "rollup-plugin-filesize": "latest",
    "tinyspawn": "latest",
    "tsd": "latest"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js --bundleConfigAsCjs",
    "clean:build": "rm -rf dist/index.js",
    "dev": "pnpm run build -- -w",
    "lint": "tsd",
    "prebuild": "pnpm run clean:build",
    "prepublishOnly": "pnpm run build",
    "pretest": "pnpm run lint && pnpm run build",
    "test": "ava --verbose"
  },
  "license": "MIT",
  "ava": {
    "timeout": "1m"
  },
  "tsd": {
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "@microlink/function": [
          "./src/index.d.ts"
        ]
      }
    },
    "directory": "test"
  }
}
