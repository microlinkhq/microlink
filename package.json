{
  "name": "microlink",
  "description": "The Microlink API organized into products, each returning a direct result",
  "homepage": "https://github.com/microlinkhq/microlink",
  "version": "",
  "author": {
    "email": "hello@microlink.io",
    "name": "microlink.io",
    "url": "https://microlink.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microlinkhq/microlink.git"
  },
  "bugs": {
    "url": "https://github.com/microlinkhq/microlink/issues"
  },
  "keywords": [
    "api",
    "extract",
    "lighthouse",
    "markdown",
    "metadata",
    "microlink",
    "mql",
    "pdf",
    "scraper",
    "screenshot",
    "seo"
  ],
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@lerna-lite/cli": "latest",
    "@lerna-lite/publish": "latest",
    "c8": "latest",
    "finepack": "latest",
    "git-authors-cli": "latest",
    "github-generate-release": "latest",
    "nano-staged": "latest",
    "simple-git-hooks": "latest",
    "standard": "latest",
    "standard-markdown": "latest"
  },
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "clean": "pnpm --recursive exec -- rm -rf node_modules",
    "contributors": "pnpm run contributors:add && pnpm run contributors:commit",
    "contributors:add": "pnpm --recursive --parallel exec -- finepack",
    "contributors:commit": "(git-authors-cli && finepack && git add package.json && git commit -m 'build: contributors' --no-verify) || true",
    "lint": "standard-markdown README.md && standard",
    "postrelease": "github-generate-release",
    "pretest": "pnpm run lint",
    "release": "lerna publish --yes --sort --conventional-commits --changelog-preset conventionalcommits -m \"chore(release): %s\"",
    "test": "c8 pnpm --recursive --sequential test"
  },
  "private": true,
  "license": "MIT",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "nano-staged": {
    "*.js": [
      "npx @kikobeats/prettier-standard",
      "standard --fix"
    ],
    "package.json": [
      "finepack"
    ]
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit",
    "pre-commit": "npx nano-staged"
  },
  "standard": {
    "ignore": [
      "packages/function/dist",
      "packages/mql/dist",
      "packages/search/docs/static"
    ]
  }
}
